{
  "name": "kauri",
  "version": "0.1.0",
  "description": "A deterministic record database for LLM agents and humans",
  "type": "module",
  "license": "MIT",
  "bin": {
    "kauri": "./dist/kauri"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mhashim6/kauri.git"
  },
  "homepage": "https://github.com/mhashim6/kauri",
  "bugs": "https://github.com/mhashim6/kauri/issues",
  "keywords": [
    "decisions",
    "architecture",
    "mcp",
    "llm",
    "agent",
    "claude-code",
    "sqlite"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "embed-migrations": "bun run scripts/embed-migrations.ts",
    "prebuild": "bun run embed-migrations",
    "build": "bun run scripts/build.ts",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:cli": "bun test tests/cli",
    "test:mcp": "bun test tests/mcp",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "lefthook": "^2.1.6",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2"
  }
}
